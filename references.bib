@article{NIEDERMEYER19883,
title = {Benign occipital lobe epilepsy},
journal = {Journal of Epilepsy},
volume = {1},
number = {1},
pages = {3-11},
year = {1988},
issn = {0896-6974},
doi = {https://doi.org/10.1016/S0896-6974(88)80027-6},
url = {https://www.sciencedirect.com/science/article/pii/S0896697488800276},
author = {E. Niedermeyer and Silvana Riggio and Margarida Santiago},
keywords = {Epilepsy, Occipital lobe epilepsy, Slow spike-wave complex, Migraine, Basilar artery migraine},
abstract = {Benign occipital lobe epilepsy (BOLE) represents a recently delineated form of epileptic seizure disorder. It occurs in children, adolescents, and young adults. The seizures are mostly of visual character with elementary or complex hallucinations, but nonvisual seizures also occur. The EEG usually shows runs of posterior slow spike-wave complexes interictally or during ictal episodes. Migrainelike headache may occur after the seizures and there are certain relationships between BOLE and migraine, but a line must be drawn separating these two conditions. Six typical cases are presented; diagnostic features, differential diagnosis, and possible underlying mechanisms are discussed.}
}
